{
  "name": "auralis",
  "version": "1.4.0",
  "private": true,
  "description": "Auralis — a self-hosted, local-first music platform: SQLite library with real tag/metadata extraction, secure range streaming, cover-art cache, and automatic lyric fetching (LRCLIB) saved back as .lrc sidecars. Ships as a web app, an Electron desktop app (Debian/Windows) and an Android client.",
  "homepage": "https://github.com/ybenyedder/auralis",
  "main": "desktop/main.js",
  "author": {
    "name": "Youssef Ben yedder",
    "email": "volt@webtvmedia.net"
  },
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/ybenyedder/auralis.git"
  },
  "bugs": {
    "url": "https://github.com/ybenyedder/auralis/issues"
  },
  "funding": {
    "type": "individual",
    "url": "https://paypal.me/AdamMezerai"
  },
  "scripts": {
    "dev": "next dev -p 4237",
    "build": "next build",
    "start": "NODE_ENV=production next start -p 4237",
    "serve": "NODE_ENV=production node .next/standalone/server.js",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "check": "npm run lint && npm run typecheck && npm run build",
    "desktop:dev": "AURALIS_DESKTOP_DEV=1 electron desktop/main.js",
    "desktop:prepare": "node scripts/prepare-desktop.mjs",
    "desktop:build": "npm run build && npm run desktop:prepare && electron-builder",
    "desktop:build:linux": "npm run build && npm run desktop:prepare && electron-builder --linux",
    "desktop:build:win": "npm run build && npm run desktop:prepare && electron-builder --win",
    "mobile:native": "node scripts/build-native-apk.mjs"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.525.0",
    "music-metadata": "^10.9.1",
    "next": "^16.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.3.1",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.15"
  }
}
