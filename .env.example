# ───────────────────────────────────────────────────────────────────────────
# Auralis server configuration. Copy to .env.local and adjust. All values have
# safe local-first defaults; nothing here is required to run.
# ───────────────────────────────────────────────────────────────────────────

# Absolute path to the music library that is scanned and streamed.
# Defaults to ~/Music.
AURALIS_MUSIC_DIR=/absolute/path/to/Music

# Writable directory for the SQLite database, cover-art cache and logs.
# Defaults to the platform data dir (e.g. ~/.local/share/auralis on Linux).
# AURALIS_DATA_DIR=/absolute/path/to/auralis-data

# Port the server listens on (web/standalone). Defaults to 4237.
# PORT=4237

# Optional bearer token. When set, every /api request must present it
# (Authorization: Bearer <token> or ?token=<token>). Leave empty for open LAN.
# AURALIS_TOKEN=

# Initial admin password. If unset, a RANDOM one is generated on first run and
# written to <AURALIS_DATA_DIR>/INITIAL_ADMIN_PASSWORD.txt (mode 0600) — log in,
# change it in Settings, then delete that file. Set this to choose your own.
# AURALIS_ADMIN_PASSWORD=

# Trust X-Forwarded-For / X-Real-IP for the login rate-limiter ONLY behind a
# reverse proxy you control (otherwise these client-controlled headers let an
# attacker mint a fresh bucket per request). Defaults to off.
# AURALIS_TRUST_PROXY=1

# CSRF / same-origin: cookie-authenticated mutations require an Origin matching the
# request host. Behind a reverse proxy that REWRITES Host and doesn't forward the
# real public host in X-Forwarded-Host, set this comma-separated allowlist of the
# public origin(s) so legitimate writes aren't rejected with 403.
# AURALIS_ALLOWED_ORIGINS=https://music.example.com

# Extra LAN host allowed to load `npm run dev` resources (phone testing), e.g. your
# machine's LAN IP. localhost / 127.0.0.1 are always allowed.
# AURALIS_DEV_ORIGIN=192.168.1.50

# Lyrics: when a track has no .lrc sidecar and none is cached, fetch from the
# open LRCLIB database, then cache it (DB + .lrc sidecar). Set to false to stay
# fully offline. Defaults to true.
# AURALIS_LYRICS_ONLINE=true

# Query Musixmatch for WORD-by-word (richsync) karaoke lyrics, tried before LRCLIB.
# It is the only source with per-word timing; a miss falls back to LRCLIB line-level.
# Uses an unofficial endpoint (no key) so it may break/rate-limit. Defaults to true.
# AURALIS_LYRICS_MUSIXMATCH=true

# Lyrics provider base URL. Point this at a self-hosted LRCLIB mirror if you run
# one. Defaults to https://lrclib.net.
# AURALIS_LYRICS_ENDPOINT=https://lrclib.net

# Keyless plain-lyrics fallback queried when LRCLIB finds nothing (lyrics.ovh).
# Set to empty to disable the fallback. Defaults to https://api.lyrics.ovh.
# AURALIS_LYRICS_FALLBACK=https://api.lyrics.ovh

# Whether fetched lyrics are written back next to the audio file as a .lrc
# sidecar (true self-hosting). Defaults to true.
# AURALIS_LYRICS_SIDECAR=true

# Log level (debug|info|warn|error) and format (text|json).
# AURALIS_LOG_LEVEL=info
# AURALIS_LOG_FORMAT=text
